# =========================================================================
# Skylink Bundlefasta Dashboard - Environment Variables Template
# Copy this file to .env.local and fill in the values.
# =========================================================================

# 1. NEXT.JS ENVIRONMENT
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 2. SUPABASE CONFIGURATION
# Client publishable keys (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only secret key (Bypasses Row Level Security (RLS), KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 3. DARAJA (M-PESA) API CONFIGURATION
# Environment: 'sandbox' or 'production' / 'live'
DARAJA_ENV=sandbox
DARAJA_ENVIRONMENT=sandbox

# Daraja credentials
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret

# M-Pesa Shortcode (PayBill or Store number)
DARAJA_SHORTCODE=600997

# Lipa Na M-Pesa Passkey (Used for STK push / online checkout query)
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# API username created on M-Pesa portal (for B2C, Reversal, Balance queries)
DARAJA_INITIATOR_NAME=your-initiator-username

# Initiator password configured on M-Pesa portal
DARAJA_INITIATOR_PASSWORD=your-initiator-password

# RSA Public Certificate string for credential encryption (or leave empty to load SandboxCertificate.cer/ProductionCertificate.cer locally)
DARAJA_CERTIFICATE=

# B2C Command Type: 'SalaryPayment' (used by Pesatrix), 'BusinessPayment', or 'PromotionPayment' (default)
DARAJA_B2C_COMMAND_ID=PromotionPayment

# 4. CUSTOM WEBHOOK CALLBACK OVERRIDES (Optional - defaults to /api/daraja/callback/*)
DARAJA_CALLBACK_URL=http://localhost:3000/api/daraja/callback/stk
DARAJA_B2C_RESULT_URL=http://localhost:3000/api/daraja/callback/b2c
DARAJA_B2C_TIMEOUT_URL=http://localhost:3000/api/daraja/callback/b2c-timeout
DARAJA_REVERSAL_RESULT_URL=http://localhost:3000/api/daraja/callback/reversal
DARAJA_REVERSAL_TIMEOUT_URL=http://localhost:3000/api/daraja/callback/reversal-timeout
DARAJA_BALANCE_RESULT_URL=http://localhost:3000/api/daraja/callback/balance
DARAJA_BALANCE_TIMEOUT_URL=http://localhost:3000/api/daraja/callback/balance-timeout

# 5. SECURITY CALLBACK IP WHITELIST (Optional - Comma separated client IPs allowed to hit callbacks)
SAFARICOM_IP_WHITELIST=
